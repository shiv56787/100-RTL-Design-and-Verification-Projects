class test extends uvm_test;
  `uvm_component_utils(test)
    env envh;
    
  function new(string name, uvm_component parent);
    super.new(name, parent);
  endfunction

  function void build_phase(uvm_phase phase);
    super.build_phase(phase);
     envh = env::type_id::create("envh", this);
  endfunction

  task run_phase(uvm_phase phase);
    seq_rst seq_rst_h;
    seq seqh;
    seq_rst_h = seq_rst::type_id::create("seq_rst_h");
    seqh = seq::type_id::create("seqh");
    repeat(10) begin
    phase.raise_objection(this);
    seq_rst_h.start(envh.agenth.seqrh);
    seqh.start(envh.agenth.seqrh);
    #600000;
    phase.drop_objection(this);
    end
  endtask

  function void end_of_elaboration_phase(uvm_phase phase);
    super.end_of_elaboration_phase(phase);
    uvm_top.print_topology();
  endfunction

endclass

module top;

  logic clk;
  uart_if uart_if_inst(clk);

  initial begin
    clk = 0;
    forever #5 clk = ~clk;
  end

  uart_tx #(.data_width(DATA_WIDTH)) uart_tx_inst(
    .clk(clk),
    .rst(uart_if_inst.rst),
    .baud_tick(uart_if_inst.baud_tick),
    .tx_start(uart_if_inst.tx_start),
    .data_in(uart_if_inst.tx_data),
    .tx(uart_if_inst.tx),
    .tx_done(uart_if_inst.tx_done),
    .tx_busy(uart_if_inst.tx_busy)
  );

  baud_gen baud_inst(
  .clk(clk),
  .rst(uart_if_inst.rst),
  .tick(uart_if_inst.baud_tick)
  );


  uart_rx #(.data_width(DATA_WIDTH)) uart_rx_inst(
  .clk(clk),
  .rst(uart_if_inst.rst),
  .baud_tick(uart_if_inst.baud_tick),
  .rx(uart_if_inst.tx),
  .data_out(uart_if_inst.rx_data),
  .rx_done(uart_if_inst.rx_done)
);

  initial begin
    uvm_config_db#(virtual uart_if)::set(null, "*", "vif", uart_if_inst);
    run_test("test");
  end

endmodule
